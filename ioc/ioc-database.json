  "dangerous_prerequisites": {
    "_description": "Patterns in README files that indicate dangerous installation prerequisites.",
    "patterns": [
      "curl.*\\|.*sh",
      "curl.*\\|.*bash",
      "wget.*\\|.*sh",
      "wget.*\\|.*bash",
      "pip install.*--break-system-packages",
      "chmod 777",
      "chmod \\+x.*&&.*\\./",
      "sudo.*curl",
      "npm install -g.*&&",
      "docker run.*--privileged",
      "LD_PRELOAD",
      "DYLD_INSERT_LIBRARIES",
      "NODE_OPTIONS.*--require"
    ]
  },
  "mcp_attack_patterns": {
    "_description": "Patterns indicating MCP server manipulation, response poisoning, or trust boundary violations.",
    "patterns": [
      {
        "pattern": "tool_result.*\\{.*\"text\".*ignore.*previous",
        "description": "MCP response injection: tool result contains prompt injection",
        "severity": "CRITICAL"
      },
      {
        "pattern": "server.*proxy.*forward.*tool_call",
        "description": "MCP proxy interception: man-in-the-middle on tool calls",
        "severity": "HIGH"
      },
      {
        "pattern": "override.*tool_name|replace.*tool_call|intercept.*function",
        "description": "MCP tool shadowing: replacing legitimate tool calls",
        "severity": "HIGH"
      }
    ]
  },
  "shell_decode_patterns": {
    "_description": "Shell command patterns that decode and execute obfuscated payloads. Added v1.1.6.",
    "patterns": [
      "base64\\s+-d\\s*\\|\\s*(ba)?sh",
      "base64\\s+--decode\\s*\\|\\s*(ba)?sh",
      "echo\\s+[A-Za-z0-9+/=]{20,}\\s*\\|\\s*base64\\s+-d",
      "python3?\\s+-c\\s+.*base64.*decode.*exec",
      "perl\\s+-e\\s+.*decode_base64.*system",
      "printf\\s+.*\\\\x[0-9a-f]{2}.*\\|\\s*(ba)?sh",
      "xxd\\s+-r\\s+-p\\s*\\|\\s*(ba)?sh"
    ]
  },
